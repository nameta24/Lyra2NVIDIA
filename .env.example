# ── Modal.com credentials ────────────────────────────────────────────────────
# Get these from: https://modal.com/settings/tokens
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# ── HuggingFace token (for Lyra weights) ─────────────────────────────────────
# Get from: https://huggingface.co/settings/tokens
# Must have accepted the Lyra license: https://huggingface.co/nvidia/Lyra
HF_TOKEN=your_huggingface_token_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Override API host if deploying remotely
API_BASE_URL=http://localhost:8000
